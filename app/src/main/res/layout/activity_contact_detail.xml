<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            app:navigationIcon="?attr/homeAsUpIndicator" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Action Buttons: Call, Message, WhatsApp -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCall"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:text="Call"
                    android:textAllCaps="false"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textSize="13sp"
                    app:icon="@drawable/ic_phone"
                    app:iconSize="18dp"
                    app:iconGravity="textStart"
                    app:iconPadding="4dp"
                    app:backgroundTint="@color/action_btn_bg"
                    android:textColor="@color/accent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMessage"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginHorizontal="6dp"
                    android:layout_weight="1"
                    android:text="SMS"
                    android:textAllCaps="false"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textSize="13sp"
                    app:icon="@drawable/ic_message"
                    app:iconSize="18dp"
                    app:iconGravity="textStart"
                    app:iconPadding="4dp"
                    app:backgroundTint="@color/action_btn_bg"
                    android:textColor="@color/accent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWhatsApp"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="WhatsApp"
                    android:textAllCaps="false"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textSize="13sp"
                    app:icon="@drawable/ic_whatsapp"
                    app:iconSize="18dp"
                    app:iconGravity="textStart"
                    app:iconPadding="4dp"
                    app:iconTint="@null"
                    app:backgroundTint="@color/action_btn_bg"
                    android:textColor="#25D366" />

            </LinearLayout>

            <!-- Contact Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Prefix -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prefix"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/editPrefix"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="Dr., Mr., Ms., etc."
                        android:inputType="textCapWords"
                        android:minHeight="40dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_tertiary"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="8dp"
                        android:background="@color/divider" />

                    <!-- Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Name *"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/editName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="Full name"
                        android:inputType="textPersonName|textCapWords"
                        android:minHeight="40dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_tertiary"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="8dp"
                        android:background="@color/divider" />

                    <!-- Suffix -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Suffix"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/editSuffix"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="Jr., Sr., III, etc."
                        android:inputType="textCapWords"
                        android:minHeight="40dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_tertiary"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="8dp"
                        android:background="@color/divider" />

                    <!-- Phone -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phone"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/editPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="Phone number"
                        android:inputType="phone"
                        android:minHeight="40dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_tertiary"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="8dp"
                        android:background="@color/divider" />

                    <!-- Description -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/editDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="top"
                        android:hint="Notes, address, email, etc."
                        android:inputType="textMultiLine|textCapSentences"
                        android:minHeight="100dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_tertiary"
                        android:textSize="16sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
