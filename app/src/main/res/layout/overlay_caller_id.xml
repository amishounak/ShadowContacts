<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    app:cardBackgroundColor="#1C1C2E"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- App label -->
        <TextView
            android:id="@+id/overlayAppLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shadow Contacts"
            android:textColor="#98989D"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <!-- Contact name -->
        <TextView
            android:id="@+id/overlayName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Phone number -->
        <TextView
            android:id="@+id/overlayPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#0A84FF"
            android:textSize="15sp" />

        <!-- Description -->
        <TextView
            android:id="@+id/overlayDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#C7C7CC"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.3"
            android:maxLines="6"
            android:ellipsize="end"
            android:visibility="gone" />

        <!-- Tap to dismiss hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Tap to dismiss · Drag to move"
            android:textAlignment="center"
            android:textColor="#636366"
            android:textSize="11sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
